{
  "manifest_version": 3,
  "name": "Custom Behavior Handler",
  "version": "1.0.0",
  "description": "Regex-based URL redirection and tab handling.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Rewritten Link"
  },
  "options_page": "options.html",
  "declarative_net_request": {
    "rule_resources": []
  }
}